# Copia este archivo a ".env" y completa los valores reales.
# NUNCA subas el ".env" real a git (ya está en .gitignore).

# Genera una nueva con:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=cambia-esto-por-una-clave-generada-y-unica

DJANGO_DEBUG=False

# Separados por coma. Pon la IP de tu Raspberry Pi en la red local
# y/o el dominio si expones la app a internet.
DJANGO_ALLOWED_HOSTS=192.168.1.50

DJANGO_TIME_ZONE=America/Santiago
