# Cydonia (Califícame) - Plantilla de Configuración de Entorno
# Instrucciones: Copia este archivo como ".env" en la raíz del proyecto y edita los valores.
# ¡NUNCA subas el archivo ".env" real a GitHub!

# --- CONFIGURACIÓN DE SEGURIDAD ---
# Para Desarrollo (Local): Puedes usar cualquier texto simple.
# Para Producción (Raspberry Pi): DEBE ser una clave única y aleatoria.
# Genera una nueva ejecutando en tu terminal:
# python3 -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=tu-clave-secreta-local-o-de-produccion

# --- MODO DEDEPURACIÓN (DEBUG) ---
# Desarrollo: True (Muestra errores detallados en el navegador y recarga automática)
# Producción: False (Apaga errores por seguridad y optimiza rendimiento)
DJANGO_DEBUG=True

# --- CONTROL DE ACCESOS (ALLOWED HOSTS) ---
# Lista de IPs o dominios separados por comas desde los que se puede acceder a la app.
# Desarrollo: localhost,127.0.0.1
# Producción (Red Local): Usa "*" para permitir cualquier IP de tu red, o especifica la IP fija de tu Raspberry (ej: 192.168.1.123)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- ORÍGENES CONFIABLES PARA CSRF ---
# Dominios desde los que se aceptan peticiones POST (requerido detrás de Cloudflare Tunnel).
# Cada orígen debe incluir el esquema (https://). Ej:
# DJANGO_CSRF_TRUSTED_ORIGINS=https://cydonia.jorgeanais.cl,https://califica.midominio.cl
DJANGO_CSRF_TRUSTED_ORIGINS=

# --- CONFIGURACIÓN REGIONAL ---
# Zona horaria para el registro de evaluaciones y auditorías
DJANGO_TIME_ZONE=America/Santiago
